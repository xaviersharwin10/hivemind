# hivemind-remote-mcp configuration.
# Copy to .env and fill in. .env is gitignored — never commit real secrets.

# --- Enclave (the confidential recall backend) ---
ENCLAVE_URL=http://localhost:3000
HIVEMIND_NAMESPACE=
# Optional: pin the on-chain-attested enclave pubkey (hex). If unset, the server
# fetches it from the enclave /health_check (fine for the local loop only).
# ENCLAVE_PUBKEY=

# --- Server ---
PORT=8787
# Public base URL of THIS server (the OAuth `resource`). Use the deployed URL in prod.
SERVER_URL=http://localhost:8787

# --- Stytch OAuth (claude.ai Custom Connectors) ---
# Leave STYTCH_DOMAIN blank to run in open local mode (no auth).
# Project domain from Stytch dashboard → Connected Apps (e.g. https://<slug>.customers.stytch.dev).
STYTCH_DOMAIN=
STYTCH_PROJECT_ID=
STYTCH_PUBLIC_TOKEN=
# Management API key — used for per-user namespace lookup (future multi-tenant).
STYTCH_MGMT_KEY_ID=
STYTCH_MGMT_SECRET=
