{
  "name": "hivemind-memory-mcp",
  "version": "0.1.0",
  "description": "hivemind-read MCP server — recall a Telegram group's HiveMind memory and read its Seal-encrypted files from Walrus, in any MCP client (Claude, Cursor).",
  "license": "Apache-2.0",
  "type": "module",
  "bin": { "hivemind-mcp": "./dist/index.js" },
  "files": ["dist"],
  "engines": { "node": ">=18" },
  "publishConfig": { "access": "public" },
  "scripts": {
    "start": "tsx src/index.ts",
    "build": "tsup",
    "prepublishOnly": "tsup",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "@mysten-incubation/memwal": "^0.0.7",
    "@mysten/seal": "^1.1.3",
    "@mysten/sui": "^2.16.2",
    "@noble/hashes": "^1.5.0",
    "pdf-parse": "^2.4.5",
    "undici": "^6.21.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@hivemind/core": "workspace:*",
    "tsup": "^8.5.1"
  }
}
