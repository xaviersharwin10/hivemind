# --- HiveMind Flow 1 prototype ---

# Sui network for the prototype. Keep "testnet".
SUI_NETWORK=testnet

# Group OWNER private key (bech32 "suiprivkey1...").
# Leave BLANK on first run: the script generates one, prints it, and you paste it
# back here so re-runs reuse the same owner (one address = one MemWalAccount).
# In production (Option B) this is replaced by a zkLogin/Enoki signer.
SUI_PRIVATE_KEY=

# MemWal relayer. Staging = testnet.
MEMWAL_SERVER_URL=https://relayer-staging.memory.walrus.xyz

# Logical group id for the prototype (stands in for a Telegram chat id).
GROUP_ID=proto-group-1

# --- Telegram bot ---
# From @BotFather: /newbot → paste token here. Then /setprivacy → Disable.
BOT_TOKEN=

# --- zkLogin onboarding (real per-group accounts) ---
# Google Cloud OAuth web client id, registered in the Enoki portal.
GOOGLE_CLIENT_ID=
# Enoki public API key (enoki_public_...). Note: the SPA reads its own VITE_* copies
# from packages/onboard/.env — these here are for reference/parity.
ENOKI_API_KEY=
# Enoki PRIVATE API key (enoki_private_...) — server-side only, used by the bot backend
# to sponsor onboarding gas via Enoki's gas station. Get it from the Enoki Portal.
ENOKI_PRIVATE_API_KEY=
# Where the onboarding SPA is served (the bot puts this in the link it DMs the creator).
ONBOARD_URL=http://localhost:5173
# Port for the bot's onboarding backend (the SPA POSTs the created account here).
BOT_API_PORT=8080
